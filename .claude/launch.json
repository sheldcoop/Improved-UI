{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/vite", "--port", "3000"],
      "port": 3000
    },
    {
      "name": "backend",
      "runtimeExecutable": "python3.11",
      "runtimeArgs": ["app.py"],
      "cwd": "${workspaceFolder}/backend",
      "port": 5001
    }
  ]
}
